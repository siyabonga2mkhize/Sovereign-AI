                        <foaf:givenName>Nhlawulo</foaf:givenName>
                    </foaf:Person>
                </rdf:li>
            </rdf:Seq>
        </bib:authors>
        <dc:title>How Well Do Large Language Models Understand Your Home Language? The Data Says: Unevenly.</dc:title>
        <dcterms:abstract>Multilingual language models often claim support for hundreds of languages, but how well do they actually perform in low-resource ones? AFROBENCH evaluates multilingual NLP systems across 64 African languages, 15 tasks, and 22 datasets, revealing a clear performance gap driven by uneven language data and digital representation.</dcterms:abstract>
        <dc:date>April 30, 2026</dc:date>
        <dc:identifier>
            <dcterms:URI>
                <rdf:value>https://lelapa.ai/blog/how-well-do-llms-understand-your-home-language</rdf:value>
            </dcterms:URI>
        </dc:identifier>
        <dcterms:dateSubmitted>2026-07-16 11:19:00</dcterms:dateSubmitted>
        <z:shortTitle>How Well Do Large Language Models Understand Your Home Language?</z:shortTitle>
        <z:language>en</z:language>
    </bib:Document>
